// GoodRoads - Schema do banco de dados
// Postgres + extensao PostGIS para geolocalizacao nativa (ver secao 3.2 de docs/ARQUITETURA_GOODROADS.md)

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
  // "native" cobre o ambiente de desenvolvimento; "linux-musl-openssl-3.0.x"
  // e o alvo da imagem Docker de producao (node:20-alpine, OpenSSL 3.x). Sem
  // ele, o engine do Prisma nao carrega no container (ver Dockerfile: o
  // pacote openssl tambem precisa estar instalado para fornecer o libssl.so.3).
  binaryTargets   = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [postgis]
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum RoleName {
  CIDADAO
  FUNCIONARIO
  ADMIN
}

enum OccurrenceStatus {
  PENDENTE
  EM_ANDAMENTO
  RESOLVIDA
  CANCELADA
}

enum OccurrencePriority {
  BAIXA
  MEDIA
  ALTA
  URGENTE
}

enum NotificationType {
  STATUS_CHANGE
  SYSTEM
}

// ---------------------------------------------------------------------------
// Multi-tenancy
// ---------------------------------------------------------------------------

model Municipality {
  id           String   @id @default(uuid())
  name         String
  slug         String   @unique
  logoUrl      String?
  primaryColor String?  @default("#1B7A3E")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  users       User[]
  teams       Team[]
  occurrences Occurrence[]

  @@map("municipalities")
}

// ---------------------------------------------------------------------------
// RBAC
// ---------------------------------------------------------------------------

model Role {
  id    String   @id @default(uuid())
  name  RoleName @unique
  users User[]

  @@map("roles")
}

// ---------------------------------------------------------------------------
// Usuarios
// ---------------------------------------------------------------------------

model User {
  id             String    @id @default(uuid())
  municipalityId String?   @map("municipality_id")
  roleId         String    @map("role_id")
  name           String
  email          String    @unique
  passwordHash   String    @map("password_hash")
  cpf            String?   @unique
  birthDate      DateTime? @map("birth_date")
  phone          String?
  avatarUrl      String?   @map("avatar_url")
  active         Boolean   @default(true)
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  municipality Municipality? @relation(fields: [municipalityId], references: [id])
  role         Role          @relation(fields: [roleId], references: [id])

  occurrencesReported Occurrence[]               @relation("OccurrenceCitizen")
  occurrencesAssigned Occurrence[]               @relation("OccurrenceAssignee")
  statusChanges       OccurrenceStatusHistory[]
  refreshTokens       RefreshToken[]
  passwordResetTokens PasswordResetToken[]
  notifications       Notification[]
  auditLogs           AuditLog[]
  deviceTokens        DeviceToken[]

  @@index([municipalityId])
  @@map("users")
}

// ---------------------------------------------------------------------------
// Autenticacao
// ---------------------------------------------------------------------------

model RefreshToken {
  id         String    @id @default(uuid())
  userId     String    @map("user_id")
  tokenHash  String    @unique @map("token_hash")
  userAgent  String?   @map("user_agent")
  ipAddress  String?   @map("ip_address")
  expiresAt  DateTime  @map("expires_at")
  revokedAt  DateTime? @map("revoked_at")
  replacedBy String?   @map("replaced_by")
  createdAt  DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

model PasswordResetToken {
  id        String    @id @default(uuid())
  userId    String    @map("user_id")
  tokenHash String    @unique @map("token_hash")
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("password_reset_tokens")
}

// ---------------------------------------------------------------------------
// Times e categorias
// ---------------------------------------------------------------------------

model Team {
  id             String  @id @default(uuid())
  municipalityId String? @map("municipality_id")
  name           String

  municipality Municipality? @relation(fields: [municipalityId], references: [id])
  occurrences  Occurrence[]

  @@map("teams")
}

model Category {
  id     String  @id @default(uuid())
  name   String  @unique
  icon   String?
  color  String?
  active Boolean @default(true)

  occurrences Occurrence[]

  @@map("categories")
}

// ---------------------------------------------------------------------------
// Ocorrencias
// ---------------------------------------------------------------------------

model Occurrence {
  id              String             @id @default(uuid())
  protocolNumber  String             @unique @map("protocol_number")
  municipalityId  String?            @map("municipality_id")
  citizenId       String             @map("citizen_id")
  categoryId      String?            @map("category_id")
  teamId          String?            @map("team_id")
  assignedToId    String?            @map("assigned_to_id")
  description     String
  status          OccurrenceStatus   @default(PENDENTE)
  priority        OccurrencePriority @default(MEDIA)
  latitude        Float
  longitude       Float
  address         String?
  internalNotes   String?            @map("internal_notes")
  createdAt       DateTime           @default(now()) @map("created_at")
  updatedAt       DateTime           @updatedAt @map("updated_at")
  resolvedAt      DateTime?          @map("resolved_at")

  municipality Municipality? @relation(fields: [municipalityId], references: [id])
  citizen      User          @relation("OccurrenceCitizen", fields: [citizenId], references: [id])
  assignedTo   User?         @relation("OccurrenceAssignee", fields: [assignedToId], references: [id])
  category     Category?     @relation(fields: [categoryId], references: [id])
  team         Team?         @relation(fields: [teamId], references: [id])

  photos         OccurrencePhoto[]
  statusHistory  OccurrenceStatusHistory[]
  notifications  Notification[]

  // NOTA: o campo geoespacial nativo do PostGIS (`geography(Point, 4326)`) e
  // adicionado via migration SQL customizada (ver prisma/migrations), pois o
  // Prisma ainda nao modela tipos PostGIS nativamente. latitude/longitude
  // ficam como colunas de leitura simples; a coluna `location` (geography)
  // e mantida em sincronia por trigger e usada nas queries de proximidade
  // (ST_DWithin) no modulo `map`.

  @@index([municipalityId])
  @@index([citizenId])
  @@index([status])
  @@map("occurrences")
}

model OccurrencePhoto {
  id            String   @id @default(uuid())
  occurrenceId  String   @map("occurrence_id")
  url           String
  thumbnailUrl  String?  @map("thumbnail_url")
  storageKey    String   @map("storage_key")
  order         Int      @default(0)
  createdAt     DateTime @default(now()) @map("created_at")

  occurrence Occurrence @relation(fields: [occurrenceId], references: [id], onDelete: Cascade)

  @@index([occurrenceId])
  @@map("occurrence_photos")
}

model OccurrenceStatusHistory {
  id             String            @id @default(uuid())
  occurrenceId   String            @map("occurrence_id")
  previousStatus OccurrenceStatus? @map("previous_status")
  newStatus      OccurrenceStatus  @map("new_status")
  changedById    String            @map("changed_by_id")
  note           String?
  changedAt      DateTime          @default(now()) @map("changed_at")

  occurrence Occurrence @relation(fields: [occurrenceId], references: [id], onDelete: Cascade)
  changedBy  User       @relation(fields: [changedById], references: [id])

  @@index([occurrenceId])
  @@map("occurrence_status_history")
}

// ---------------------------------------------------------------------------
// Notificacoes
// ---------------------------------------------------------------------------

model Notification {
  id           String            @id @default(uuid())
  userId       String            @map("user_id")
  occurrenceId String?           @map("occurrence_id")
  type         NotificationType  @default(STATUS_CHANGE)
  title        String
  body         String
  read         Boolean           @default(false)
  createdAt    DateTime          @default(now()) @map("created_at")

  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  occurrence Occurrence? @relation(fields: [occurrenceId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@map("notifications")
}

// ---------------------------------------------------------------------------
// Contador de protocolo (numeracao sequencial e atomica por ano)
// ---------------------------------------------------------------------------

model ProtocolSequence {
  year      Int @id
  lastValue Int @default(0) @map("last_value")

  @@map("protocol_sequences")
}

// ---------------------------------------------------------------------------
// Auditoria
// ---------------------------------------------------------------------------

model AuditLog {
  id        String   @id @default(uuid())
  userId    String?  @map("user_id")
  action    String
  entity    String
  entityId  String?  @map("entity_id")
  metadata  Json?
  ipAddress String?  @map("ip_address")
  createdAt DateTime @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([entity, entityId])
  @@map("audit_logs")
}

// ---------------------------------------------------------------------------
// Push notifications (Etapa 5 — FCM)
// ---------------------------------------------------------------------------

// Um usuario pode ter varios tokens (varios dispositivos/instalacoes). O
// token e a chave unica: se o mesmo device registrar novamente (reinstalou
// o app, por exemplo), fazemos upsert em vez de duplicar.
model DeviceToken {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  token     String   @unique
  platform  String? // 'android' | 'ios' | outros no futuro
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("device_tokens")
}
