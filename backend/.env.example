# --- App ---
NODE_ENV=development
PORT=3333
API_PREFIX=/api/v1

# --- Database ---
# Postgres com extensao PostGIS habilitada (ver docker-compose.yml)
DATABASE_URL="postgresql://goodroads:goodroads@localhost:5432/goodroads?schema=public"

# --- JWT (RS256) ---
# Gere um par de chaves de desenvolvimento com:
#   npm run keys:generate
# Em producao, as chaves devem vir de um cofre de segredos (nao versionar em .env).
JWT_PRIVATE_KEY_PATH=./keys/dev/private.pem
JWT_PUBLIC_KEY_PATH=./keys/dev/public.pem
JWT_ACCESS_TOKEN_TTL=15m
JWT_REFRESH_TOKEN_TTL_DAYS=30

# --- CORS ---
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# --- Storage local (dev) ---
STORAGE_DRIVER=local
LOCAL_STORAGE_DIR=./uploads
LOCAL_STORAGE_PUBLIC_URL=http://localhost:3333/uploads

# --- Storage S3-compativel (producao futura) ---
# STORAGE_DRIVER=s3
# S3_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
# S3_BUCKET=goodroads-photos
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_REGION=auto

# --- Firebase Cloud Messaging (push, Etapa 5) ---
# PUSH_DRIVER=noop mantem o comportamento das Etapas 1-4 (so loga a
# intencao de envio, sem exigir credenciais). Para push real:
#   1. Console do Firebase > Configuracoes do projeto > Contas de servico
#   2. "Gerar nova chave privada" -> baixa um JSON
#   3. Salve em keys/dev/firebase-service-account.json (NUNCA versionar)
#   4. PUSH_DRIVER=fcm
PUSH_DRIVER=noop
FCM_SERVICE_ACCOUNT_PATH=./keys/dev/firebase-service-account.json

# --- Rate limiting ---
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100
AUTH_RATE_LIMIT_MAX=10
